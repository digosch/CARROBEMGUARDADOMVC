@model Estacionamento.Web.ViewModels.TabelaPrecoIndexViewModel

@{
    ViewData["Title"] = "Tabela de Preços";
}

<style>
    .cabecalho-tabela { background-color: #4a69bd; color: white; }
    .mensagem-sucesso { color: green; }
    .mensagem-erro { color: red; }
</style>

<h1>Tabela de Preços</h1>

@if (TempData["Mensagem"] != null)
{
    <p class="@(TempData["Sucesso"] as bool? == true ? "mensagem-sucesso" : "mensagem-erro")">
        @TempData["Mensagem"]
    </p>
}

<form asp-action="Cadastrar" asp-controller="TabelaPreco" method="post" class="mb-4">
    <div class="row g-2 align-items-end">
        <div class="col-auto">
            <label asp-for="NovaTabela.DataInicioVigencia">Data Início Vigência</label>
            <input asp-for="NovaTabela.DataInicioVigencia" type="text" placeholder="dd/mm/aaaa" maxlength="10" class="form-control mascara-data" />
            <span asp-validation-for="NovaTabela.DataInicioVigencia" class="mensagem-erro"></span>
        </div>
        <div class="col-auto">
            <label asp-for="NovaTabela.DataFimVigencia">Data Fim Vigência</label>
            <input asp-for="NovaTabela.DataFimVigencia" type="text" placeholder="dd/mm/aaaa" maxlength="10" class="form-control mascara-data" />
            <span asp-validation-for="NovaTabela.DataFimVigencia" class="mensagem-erro"></span>
        </div>
        <div class="col-auto">
            <label asp-for="NovaTabela.ValorHoraInicial">Valor Hora Inicial</label>
            <input asp-for="NovaTabela.ValorHoraInicial" type="text" placeholder="0.00" maxlength="8" class="form-control mascara-valor" />
            <span asp-validation-for="NovaTabela.ValorHoraInicial" class="mensagem-erro"></span>
        </div>
        <div class="col-auto">
            <label asp-for="NovaTabela.ValorHoraAdicional">Valor Hora Adicional</label>
            <input asp-for="NovaTabela.ValorHoraAdicional" type="text" placeholder="0.00" maxlength="8" class="form-control mascara-valor" />
            <span asp-validation-for="NovaTabela.ValorHoraAdicional" class="mensagem-erro"></span>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Cadastrar</button>
        </div>
    </div>
</form>

<table class="table table-bordered">
    <thead>
        <tr class="cabecalho-tabela">
            <th>Data Início Vigência</th>
            <th>Data Fim Vigência</th>
            <th>Valor Hora Inicial</th>
            <th>Valor Hora Adicional</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var tabela in Model.Tabelas)
        {
            <tr>
                <td>@tabela.DataInicioVigencia.ToString("dd/MM/yyyy")</td>
                <td>@tabela.DataFimVigencia.ToString("dd/MM/yyyy")</td>
                <td>@tabela.ValorHoraInicial.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</td>
                <td>@tabela.ValorHoraAdicional.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</td>
            </tr>
        }
    </tbody>
</table>

<script>
    document.querySelectorAll('.mascara-data').forEach(function (campo) {
        campo.addEventListener('input', function () {
            let v = campo.value.replace(/\D/g, '').slice(0, 8);
            if (v.length > 4) v = v.slice(0, 2) + '/' + v.slice(2, 4) + '/' + v.slice(4);
            else if (v.length > 2) v = v.slice(0, 2) + '/' + v.slice(2);
            campo.value = v;
        });
    });

    document.querySelectorAll('.mascara-valor').forEach(function (campo) {
        campo.addEventListener('input', function () {
            let v = campo.value.replace(/[^\d.]/g, '');
            const partes = v.split('.');
            if (partes.length > 2) v = partes[0] + '.' + partes.slice(1).join('');
            campo.value = v;
        });
    });
</script>
